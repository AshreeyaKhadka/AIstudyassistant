# Server settings
FLASK_APP=app.py
FLASK_ENV=development
FLASK_RUN_PORT=5000
SECRET_KEY=your-super-secret-key

# Database Settings
DATABASE_URL=postgresql://ce_user:secretpassword@localhost:5432/ce_study_assistant

# Google OAuth 2.0 Credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
ALLOWED_EMAIL_DOMAIN= # e.g. pu.edu.np

# AI / Embeddings
LLM_PROVIDER=placeholder # placeholder | claude | openai | ollama
EMBEDDING_PROVIDER=placeholder # placeholder | openai | sentence_transformers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
