{
  "Pokhara University - Bachelor in Computer Engineering": {
    "Data Communication (3-0-2)": {
      "credits": "3-0-2",
      "units": [
        {
          "unit": "Unit 1",
          "title": "Introduction",
          "sub_topics": [
          "Evolution of Data Communication systems",
          "Analog and Digital Data Transmission, Data Communication Terminology",
          "Standards Organizations, Applications"
          ],
          "hours": "2 hrs"
          
        },
        {
          "unit": "Unit 2",
          "title": "Data Transmission",
          "sub_topics": [
          "Data Transmission Techniques - Parallel Transmission, Serial Transmission (Synchronous, Asynchronous and Isochronous Communication), Modes of Data Transmission",
          "Line Configuration, Bit Rate/ Baud rate, Transmission Channel, Data Rate Limits - Shannon Capacity Theorem and Nyquist Bit Rate, RS-232C (DTE-DCE, DTE-DTE)"
        ],
          "hours": "3 hrs"
        },
        {
          "unit": "Unit 3",
          "title": "Signals and Systems",
           "sub_topics": [
          "Signals and their classification: Periodic and non-periodic signals; Deterministic and Random signals; Energy and Power signals; Continuous and Discrete time signals",
          "Basic Elementary Signals - Unit Step Signal, Ramp Signal, Impulse Signal, Sinusoidal Signal, Signum Signal",
          "System - Continuous and Discrete time system",
          "Basic system properties: Linearity, Causality, Stability, Static & Dynamic, and Time Invariance, Introduction to LTI System"
        ],
          "hours": "6 hrs"
        },
        {
          "unit": "Unit 4",
          "title": "Overview of Data Communication Networking and Protocols",
          "sub_topics": [
          "Network Types, Topology",
          "OSI layers and Functions, TCP/IP layer, Local Area Networks (LAN) Architecture, LLC/MAC & Routing",
          "IEEE Standards, Ethernet (Aloha, CSMA), Wide Area Networks (WAN): X.25, Frame Relay, ATM"
        ],
          "hours": "4 hrs"
        },
        {
          "unit": "Unit 5",
          "title": "Transmission Media",
          "sub_topics": [
          "Electromagnetic Spectrum for Telecommunication",
          "Type of Propagation",
          "Guided Transmission Media: Twisted Pair Cable, Coaxial Cable, Optical Fiber, Characteristics of Unguided Communication Bands, Antennas",
          "Unguided Transmission Media: Terrestrial Microwave, Satellite Communication, VSAT, and Cellular Telephony"
        ],
          "hours": "5 hrs"
        },
        {
          "unit": "Unit 6",
          "title": "Impairments, Error Handling and Compression Techniques",
          "sub_topics": [
          "Attenuation & Distortion, Delay Distortion, Noise & Types, interference, crosstalk",
          "Types of error & its Detection and Correction Methods",
          "Data Compression, Lossless Compression - Run Length Coding, Dictionary Coding and Huffman Coding",
          "Lossy Compression - Predictive Coding and Transform Coding"
        ],
          "hours": "6 hrs"
        },
        {
          "unit": "Unit 7",
          "title": "Data Link Control and Protocol",
           "sub_topics": [
          "Framing",
          "Flow Control: Stop - & - Wait, Sliding Window, Error Control: Automatic Repeat Request (ARQ), Stop- and Wait ARQ, Sliding Window (ARQ)",
          "HDLC protocol",
          "Point- to- Point protocol"
        ],
          "hours": "5 hrs"
        },
        {
          "unit": "Unit 8",
          "title": "Multiplexing & Switching",
          "sub_topics": [
          "Multiplexing types and Application",
          "Multiplexing Vs Non- Multiplexing",
          "The Telephone System: Analog services and its Hierarchy",
          "Digital services and Hierarchy Circuit Switching, Packet Switching, Message Switching, and Private Branch Exchange"
        ],
          "hours": "5 hrs"
        },
        {
          "unit": "Unit 9",
          "title": "Data Encoding & Modulation",
          "sub_topics": [
          "Line coding - Unipolar, Polar and Bipolar signaling",
          "Digital Modulation Techniques - Amplitude, Frequency, and Phase Shift Keying",
          "Analog to Digital Conversion - Pulse Code and Delta Modulation",
          "Analog Modulation Techniques - Amplitude, Frequency, and Phase Modulation",
          "Multilevel Modulation- QPSK, QAM",
          "Introduction to Modem"
        ],
          "hours": "9 hrs"
        }
      ]
    },
    "Calculus II (3-2-0)": {
      "credits": "3-2-0",
      "units": [
        {
          "unit": "Unit I",
          "title": "Multiple Integrals",
          "sub_topics": [
          "Introduction",
          "Double integrals in Cartesian and polar form, Fubini's theorem (statement only), change of order of integration, change of variable from in double integral Jacobian matrix and reduction into Polar",
          "Triple integrals in Cartesian form and Dirichlet's Integral, use of cylindrical and spherical coordinates to evaluate triple integral",
          "Application of double and triple integrals to find Area and volume"
        ],
          "hours": "6 hrs"
        },
        {
          "unit": "Unit II",
          "title": "Series Solution of Differential Equations and Special Functions",
          "sub_topics": [
          "Power series method of solution of differential equations",
          "Legendre's Equation, Legendre's polynomials P_n(x) of x. Graph of P_1(x), P_2(x), P_3(x)",
          "Frobenius method. Bessel's equation, Bessel's function J_v(x) and its properties. Graph of J_v(x) for v=1 2"
        ],
          "hours": "6 hrs"
        },
        {
          "unit": "Unit III",
          "title": "Laplace Transform and Its Application",
          "sub_topics": [
          "Laplace Transform (LT), Inverse LT, Linearity of LT, LT of elementary functions, inverses and first shifting (shifting) theorem. Existence theorem of Laplace transform (without proof) and uniqueness",
          "Transform of Derivative and Integrals of a function",
          "Differentiation and Integration of Laplace transform",
          "Unit step function, periodic function and LT, second shifting (t-shifting) theorem",
          "Convolution theorem and its application to find inverse",
          "Application of Laplace transform to find the solutions of ordinary differential equations (IVP)"
        ],
          "hours": "8 hrs"
        },
        {
          "unit": "Unit IV",
          "title": "Advanced Vector Calculus",
          "sub_topics": [
          "Differentiation of vector function of scalar variable",
          "Point functions, Gradient, directional derivative, divergence and curl with properties (without proof)",
          "Line integral with physical interpretation and evaluation of line integrals on various path",
          "Line integral, potential function and independence of path",
          "Green's theorem in plane (without proof) and its various applications",
          "Surface integral and evaluation of surface integrals",
          "Stoke's theorem (without proof) and its applications",
          "Gauss Divergence theorem (without proof) and its applications"
        ],
          "hours": "15 hrs"
        },
        {
          "unit": "Unit V",
          "title": "Fourier Series",
          "sub_topics": [
          "Periodic Functions, odd and even functions",
          "Fourier series of 2 π periodic functions in the interval (α, α + 2 π)",
          "Fourier series of 2 1 periodic functions",
          "Fourier series of odd and even functions, sine and cosine series"
        ],
          "hours": "5 hrs"
        },
        {
          "unit": "Unit VII",
          "title": "Partial Differential Equations","sub_topics": [
          "Introduction",
          "Linear constant coefficient equation",
          "Applications in conservation laws, the breaking time, shock waves, nonlinear advection equations, and traffic flow"
        ],
          "hours": "5 hrs"
        }
      ]
    },
